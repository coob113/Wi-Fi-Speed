{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wifi-speed-web",
  "compatibility_date": "2026-06-30",
  "pages_build_output_dir": "./dist",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "wifi-speed-maps",
      "database_id": "YOUR_D1_DATABASE_ID"
    }
  ]
}

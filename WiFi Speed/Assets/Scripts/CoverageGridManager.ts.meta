  InputLines:
    - '// @input Asset.ObjectPrefab recordPrefab {"hint":"Record prefab (root has RecordMarker + wired label Text)"}'
    - '// @input SceneObject recordsParent {"hint":"Parent for spawned record markers"}'
    - '// @input SceneObject lookAtTarget {"hint":"Camera or device tracking object — markers look at this"}'
    - '// @input Component.Camera cullCamera {"hint":"Camera for FOV culling; falls back to Camera on lookAtTarget"}'
    - '// @input float gridSize = 10 {"hint":"World XZ grid cell size"}'
    - '// @input float yAtMaxMbps = -10 {"hint":"cm offset from user ref at best session % (fastest Mbps)"}'
    - '// @input float yAtMinMbps = -40 {"hint":"cm offset from user ref at worst session % (slowest Mbps)"}'
    - '// @input float heightReferenceOffset = -30 {"hint":"cm below user — bottom of height band (bars stay put while anchor is in band)"}'
    - '// @input float heightBandMaxOffset = -10 {"hint":"cm below user — top of height band (closest bars sit to user)"}'
    - '// @input float heightBandCatchUpSmooth = 2 {"hint":"How fast tracked height re-enters band when user Y moves (higher = faster)"}'
    - '// @input float userHeightSmoothSec = 0.2 {"hint":"Light filter on lookAtTarget Y (band edges only; bars use tracked anchor)"}'
    - '// @input float barHeightMoveSmooth = 10 {"hint":"Near-bar world-Y lerp speed (0 = snap; higher = faster catch-up)"}'
    - '// @input float neighborInfluence = 0.4 {"hint":"Spread sample weight at ring 1 (full Mbps stored; weight falls off per ring)"}'
    - '// @input float neighborSpreadRings = 2 {"hint":"How many grid rings beyond center receive spread samples (2 = center + 2 rings of neighbors)"}'
    - '// @input bool neighborIncludeDiagonals = true {"hint":"Spread to diagonal neighbors as well as cardinals"}'
    - '// @input float neighborRingFalloff = 0.5 {"hint":"Per-ring influence multiplier (ring 2 = neighborInfluence × this, ring 3 × this², …)"}'
    - '// @input float directSampleWeight = 1 {"hint":"Weight for a direct probe at this cell (spread uses neighborInfluence × ring falloff)"}'
    - '// @input float smoothPasses = 2 {"hint":"Smoothing passes across grid cells (1 = light, 3+ = softer blends)"}'
    - '// @input float perfNearDistance = 200 {"hint":"Near tier distance (cm) — visual sync every frame when session range changes"}'
    - '// @input float perfMidDistance = 400 {"hint":"Mid tier distance (cm) — visual sync every perfMidUpdateSec when session range changes"}'
    - '// @input float perfMidUpdateSec = 0.2 {"hint":"Mid-tier visual sync interval (seconds)"}'
    - '// @input float perfFarUpdateSec = 0.5 {"hint":"Far-tier visual sync interval (seconds)"}'
    - '// @input float interactableMaxDistance = 100 {"hint":"Disable SIK Interactable beyond this distance (cm); also requires in FOV (live check)"}'
    - '// @input float cullMaxDistance = 800 {"hint":"Max distance (cm) before marker SceneObject is disabled"}'
    - '// @input bool enableFovVisualCull = true {"hint":"When off, markers stay enabled by distance only (FOV ignored for visibility)"}'
    - '// @input float cullSphereRadius = 16 {"hint":"Sphere radius (cm) for Camera.isSphereVisible FOV test — ~grid cell size"}'
    - '// @input float cullFovCheckNearSec {"hint":"FOV re-check interval (sec) for near bars (< perfNearDistance); 0 = every frame"}'
    - '// @input float cullFovCheckMidSec = 0.15 {"hint":"FOV re-check interval (sec) for mid-distance bars"}'
    - '// @input float cullFovCheckFarSec = 0.33 {"hint":"FOV re-check interval (sec) for far bars (>= perfMidDistance)"}'
    - '// @input float cellUiMaxDistance = 3 {"hint":"Hide per-cell UI and disable pinch interactions at or beyond this distance"}'
    - '// @input bool debugLogs {"hint":"Enable verbose grid performance/debug logs"}'

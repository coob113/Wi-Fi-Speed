  InputLines:
    - '// @input Component.Text labelText {"hint":"Legacy % label (optional; detail panel replaces when wired)"}'
    - '// @input SceneObject colorTarget {"hint":"Child with RenderMeshVisual — material swapped by median % bracket"}'
    - '// @input Asset.Material[] bracketMaterials {"hint":"10 materials for 0-10%, 10-20%, … 90-100% relative speed"}'

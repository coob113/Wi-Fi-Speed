    - '// @input string[] bracketLabels {"hint":"One unique label per color bracket (0–10% Terrible … 90–100% Perfect)"}'
    - '// @input float visualSphereDefaultScale = 1 {"hint":"VisualSphere scale at rest"}'
    - '// @input float visualSphereHoverScale = 2 {"hint":"VisualSphere scale while hovered"}'
    - '// @input float visualSphereSelectScale = 1.5 {"hint":"VisualSphere scale while pinching"}'
    - '// @input float deadZoneMinSamples = 1 {"hint":"Min samples before ! dead zone (use 1 to test; production default 3)"}'
    - '// @input float deadZoneSessionPct = 1 {"hint":"Session % floor for ! when spread is wide enough (e.g. 1 = bottom 1%)"}'
    - '// @input string deadZoneHeadline = "No coverage" {"hint":"Header copy when dead zone confirmed"}'
    - '// @input float maxOpenDetailPanels = 20 {"hint":"Max detail panels open at once; oldest auto-closes when exceeded"}'
